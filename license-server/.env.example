# ERGENEKON License Server — Environment Variables
# Copy this to .env and fill in real values

# Ed25519 Private Key (PEM format, one line with \n)
ERGENEKON_SIGNING_KEY="-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2VwBCIEIGrq+dsj6Wc9PlqkBogrwdtInH1hFpmmr1ZS3u94UvvC\n-----END PRIVATE KEY-----"

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRO_MONTHLY_PRICE=price_pro_monthly_id
STRIPE_PRO_ANNUAL_PRICE=price_pro_annual_id

# Server Configuration
LICENSE_SERVER_PORT=4400

# Email (optional — for sending license keys)
# RESEND_API_KEY=re_your_resend_api_key
# FROM_EMAIL=licenses@ergenekon.dev
