# ============================================================================
# ERGENEKON License Server — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# ── Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRO_MONTHLY_PRICE=price_your_pro_monthly_price_id
STRIPE_PRO_ANNUAL_PRICE=price_your_pro_annual_price_id

# ── Ed25519 Signing Key ───────────────────────────────────────────
# Paste the full PEM private key (replace newlines with \n)
ERGENEKON_SIGNING_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_BASE64_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_API_KEY=your_secure_admin_api_key_here

# ── Server ────────────────────────────────────────────────────────
LICENSE_SERVER_PORT=4400
